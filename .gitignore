# =============================================================================
# PhysaRoute — .gitignore
# =============================================================================

# ---- Python ----------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/
.python-version

# ---- Simulator output (reproducible — keep the folders, ignore content) ----
figures/*
!figures/.gitkeep
data/*
!data/.gitkeep

# ---- IDE / editor noise ----------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ---- OS noise --------------------------------------------------------------
ehthumbs.db
desktop.ini

# ---- Local secrets / configuration -----------------------------------------
.env
.env.local
*.local
